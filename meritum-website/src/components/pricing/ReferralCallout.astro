---
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
---

<Section bg="surface" id="referral">
  <Container>
    <div class="max-w-3xl mx-auto rounded-xl border border-accent/20 bg-white p-8 lg:p-10">
      <SectionHeading tag="h2" size="2xl">
        Know a colleague who's overpaying?
      </SectionHeading>
      <p class="mt-4 text-base leading-relaxed text-text font-body">
        Refer a physician who signs up for Meritum, and you'll receive one month's subscription free once they complete their first billing cycle. You can refer up to three physicians per year, and each successful referral earns you another month at no charge.
      </p>
    </div>
  </Container>
</Section>
