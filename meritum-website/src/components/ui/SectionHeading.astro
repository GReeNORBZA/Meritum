---
interface Props {
  tag?: 'h1' | 'h2' | 'h3';
  size?: 'xl' | '2xl' | '3xl' | '4xl' | '5xl';
  class?: string;
  light?: boolean;
}

const { tag: Tag = 'h2', size = '2xl', light = false, class: className = '' } = Astro.props;

const sizeClass = {
  xl: 'text-xl lg:text-2xl',
  '2xl': 'text-2xl lg:text-3xl',
  '3xl': 'text-3xl lg:text-4xl',
  '4xl': 'text-4xl lg:text-5xl',
  '5xl': 'text-4xl lg:text-5xl',
}[size];
---

<Tag class:list={[
  "font-display font-bold",
  sizeClass,
  light ? 'text-white' : 'text-primary',
  className,
]}>
  <slot />
</Tag>
