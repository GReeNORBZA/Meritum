---
import Wordmark from './Wordmark.astro';
import { siteConfig } from '../../config/site';

const navLinks = [
  { href: '/how-it-works', label: 'How It Works' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

const legalLinks = [
  { href: '/privacy', label: 'Privacy Policy' },
  { href: '/terms', label: 'Terms of Service' },
];
---

<footer class="bg-primary text-white/90">
  <div class="mx-auto max-w-[1200px] px-6 py-16 lg:py-20">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <div class="text-xl font-display font-bold tracking-[0.04em] text-white">Meritum</div>
        <p class="mt-3 text-sm leading-relaxed text-white/70">
          {siteConfig.description}
        </p>
      </div>

      <div>
        <h3 class="text-xs font-body font-medium uppercase tracking-wider text-white/50">Navigate</h3>
        <nav class="mt-4 flex flex-col gap-2.5" aria-label="Footer navigation">
          {navLinks.map(({ href, label }) => (
            <a href={href} class="text-sm font-body text-white/70 transition-colors hover:text-white">
              {label}
            </a>
          ))}
        </nav>
      </div>

      <div>
        <h3 class="text-xs font-body font-medium uppercase tracking-wider text-white/50">Legal</h3>
        <nav class="mt-4 flex flex-col gap-2.5" aria-label="Legal">
          {legalLinks.map(({ href, label }) => (
            <a href={href} class="text-sm font-body text-white/70 transition-colors hover:text-white">
              {label}
            </a>
          ))}
        </nav>
        <a href={`mailto:${siteConfig.email}`} class="mt-4 block text-sm font-body text-white/70 transition-colors hover:text-white">
          {siteConfig.email}
        </a>
      </div>

      <div>
        <h3 class="text-xs font-body font-medium uppercase tracking-wider text-white/50">Connect</h3>
        <a
          href={siteConfig.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-2 text-sm font-body text-white/70 transition-colors hover:text-white"
          aria-label="Meritum on LinkedIn"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>

    <div class="mt-12 border-t border-white/10 pt-8">
      <div class="flex flex-col gap-2 text-xs text-white/50 sm:flex-row sm:items-center sm:justify-between">
        <p>&copy; {new Date().getFullYear()} {siteConfig.company}. All rights reserved.</p>
        <p>Plus 5% GST on all prices.</p>
      </div>
    </div>
  </div>
</footer>
