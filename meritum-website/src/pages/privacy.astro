---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/ui/Section.astro';
import Container from '../components/ui/Container.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
---

<PageLayout
  title="Privacy Policy — Meritum"
  description="Meritum's privacy policy. How we handle and protect your data."
>
  <Section>
    <Container narrow>
      <SectionHeading tag="h1" size="3xl">Privacy Policy</SectionHeading>
      <div class="mt-12 font-body text-base leading-relaxed text-text-muted lg:text-lg lg:leading-relaxed">
        <p>
          This page is being finalised. For questions, contact
          <a href="mailto:hello@meritum.ca" class="text-accent underline underline-offset-2 hover:text-accent-hover transition-colors">hello@meritum.ca</a>.
        </p>
      </div>
    </Container>
  </Section>
</PageLayout>
