---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/ui/Section.astro';
import Container from '../../components/ui/Container.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<PageLayout
  title="Blog — Meritum"
  description="Insights on medical billing, AHCIP claims, and running a smarter practice in Alberta."
>
  <Section bg="background">
    <Container>
      <header class="mb-14 max-w-2xl">
        <h1 class="font-display text-4xl font-bold text-primary lg:text-5xl">
          Blog
        </h1>
        <p class="mt-4 font-body text-lg text-text-muted">
          Practical insights for Alberta physicians on billing, compliance, and practice efficiency.
        </p>
      </header>

      {posts.length === 0 ? (
        <p class="font-body text-text-muted">No posts yet. Check back soon.</p>
      ) : (
        <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => {
            const formattedDate = post.data.date.toLocaleDateString('en-CA', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            });

            return (
              <li>
                <a
                  href={`/blog/${post.id}`}
                  class="group block h-full rounded-2xl border border-transparent bg-surface p-6 transition-shadow duration-200 hover:shadow-lg hover:border-accent/20"
                >
                  <time
                    datetime={post.data.date.toISOString()}
                    class="block text-sm text-text-muted font-body"
                  >
                    {formattedDate}
                  </time>

                  <h2 class="mt-3 font-display text-xl font-bold text-primary group-hover:text-accent transition-colors duration-200">
                    {post.data.title}
                  </h2>

                  <p class="mt-2 font-body text-text-muted leading-relaxed">
                    {post.data.description}
                  </p>

                  <span class="mt-4 inline-block font-body text-sm font-medium text-accent group-hover:underline">
                    Read more &rarr;
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </Container>
  </Section>
</PageLayout>
